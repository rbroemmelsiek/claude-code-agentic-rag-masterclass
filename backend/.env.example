SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-your-key
# Optional: OpenAI hosted vector store for Responses API file_search (Module 1 managed RAG)
OPENAI_VECTOR_STORE_ID=vs-your-vector-store-id

# LangSmith — API key + project required; tracing/endpoint optional (see langsmith.py)
LANGSMITH_API_KEY=ls-your-key
LANGSMITH_PROJECT=rag-masterclass
LANGSMITH_TRACING=true
# US (default): https://api.smith.langchain.com
# EU: https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

CORS_ORIGINS=["http://localhost:5173"]
